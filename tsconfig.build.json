{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "rootDir": ".",
    "outDir": "./dist",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "types": ["node"],
    "paths": {
      "@packages/shared/constants": ["./packages/shared/constants/index.ts"],
      "@packages/shared/types": ["./packages/shared/types/index.ts"],
      "@packages/shared/types/*": ["./packages/shared/types/*"]
    }
  },
  "include": [
    "packages/local/src/**/*.ts",
    "packages/shared/constants.ts",
    "packages/shared/types/**/*.ts"
  ],
  "exclude": ["**/*.test.ts", "**/tests/**"]
}
