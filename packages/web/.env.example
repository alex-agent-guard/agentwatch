# 前端 Live 模式 — 复制为 packages/web/.env.local（勿提交 git）

# false = Live：必须 GitHub 或 Wallet 登录，读 Supabase 真数据
# true  = Dev Mock：跳过登录，Auth 页可点 Dev Mock 看 UI
VITE_USE_MOCK=false

# Supabase 项目（Dashboard → Settings → API）
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Live 激活码门禁（Live 模式默认 true；本地调试可设 false）
# VITE_LIVE_GATE=false
