{
  "name": "@agentwatch/cli",
  "version": "0.1.0",
  "description": "AgentWatch CLI — MCP security proxy, HMAC audit chain, L0/L1 risk detection, and tamper-proof log verification",
  "type": "module",
  "main": "./dist/packages/local/src/cli/index.js",
  "types": "./dist/packages/local/src/cli/index.d.ts",
  "bin": {
    "agentwatch": "./dist/packages/local/src/cli/index.js"
  },
  "imports": {
    "@packages/shared/constants": "./dist/packages/shared/constants/index.js",
    "@packages/shared/types": "./dist/packages/shared/types/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/fix-dist-imports.mjs",
    "typecheck": "npm run typecheck --prefix packages/local",
    "test": "npm run test --prefix packages/local",
    "bench": "npm run bench --prefix packages/local",
    "pack:verify": "npm run build && PACK_VERIFY=1 npm run test:pack --prefix packages/local",
    "start": "npm run start --prefix packages/local"
  },
  "keywords": [
    "mcp",
    "agentwatch",
    "security",
    "json-rpc",
    "middleware"
  ],
  "author": "AgentWatch",
  "license": "ISC",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "byline": "^5.0.0",
    "chalk": "^5.6.2",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
